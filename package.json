{
  "name": "beachside-racetrack",
  "version": "1.0.0",
  "description": "Real-time racetrack management system for Beachside Racetrack",
  "main": "server.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/dist/output.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/dist/output.css --watch",
    "start": "npm run build:css && node server.js",
    "dev": "concurrently --kill-others-on-fail -n \"CSS,SRV\" \"npm run watch:css\" \"cross-env NODE_ENV=development node server.js\""
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1"
  }
}
